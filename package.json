{
  "name": "yaml-converter",
  "version": "0.3.0",
  "type": "module",
  "description": "Convert YAML files to Excel and back with schema-driven validation",
  "bin": {
    "yaml-converter": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node && node -e \"const fs=require('fs');const f='dist/cli.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));fs.chmodSync(f,'755')\"",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "demo": "bash demo/run.sh",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "release": "bun run build && changeset publish"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dayjs": "^1.11.10",
    "exceljs": "^4.4.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.6.0",
    "@changesets/cli": "^2.27.0",
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
